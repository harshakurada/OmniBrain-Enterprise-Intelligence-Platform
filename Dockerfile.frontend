# ==============================================================================
# OmniBrain - Frontend Production Dockerfile (Module 7)
# The Streamlit UI only talks to the backend over HTTP (see frontend/app.py's
# imports: os, sys, datetime, httpx, streamlit, dotenv), so it gets its own
# minimal image/dependency set (requirements-frontend.txt) instead of the
# full backend stack (LangChain/LangGraph/PyMuPDF/faiss/etc) -- smaller
# image, faster build and startup, smaller attack surface.
# ==============================================================================

FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/workspace

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --uid 1000 omnibrain

COPY requirements-frontend.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements-frontend.txt

COPY frontend/ frontend/
COPY .streamlit/ .streamlit/

RUN chown -R omnibrain:omnibrain /workspace

USER omnibrain

EXPOSE 8501

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

CMD ["streamlit", "run", "frontend/app.py", "--server.port", "8501", "--server.address", "0.0.0.0"]
