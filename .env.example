# ==============================================================================
# OmniBrain - Central Configuration Settings (Example)
# ==============================================================================

# General
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME="OmniBrain – Agentic Multi-Modal RAG Orchestrator"

# FastAPI Backend Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:8501", "http://127.0.0.1:8501"]

# Streamlit Frontend Settings
FRONTEND_PORT=8501
BACKEND_URL=http://localhost:8000

# Database Settings
DATABASE_URL=sqlite:///./omnibrain.db

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/omnibrain.log
LOG_ROTATION="10 MB"
LOG_BACKUP_COUNT=5

# OpenAI Settings
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Ingestion / Chunking Settings
UPLOAD_DIR=storage/uploads
ASSETS_DIR=storage/assets
MAX_FILE_SIZE_MB=50
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_RETRIES=3

# Vector Database Settings (Qdrant preferred, auto-falls back to local FAISS)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=omnibrain_vectors
VECTOR_DIMENSION=1536
FAISS_STORAGE_PATH=storage/faiss_index

# Semantic Search Settings
SEARCH_DEFAULT_TOP_K=5

# Observability Settings (Placeholders for future modules)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
