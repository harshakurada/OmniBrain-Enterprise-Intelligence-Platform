# ==============================================================================
# OmniBrain - Central Configuration Settings (Example)
# Copy this file to `.env` and fill in real values before running the app.
# ==============================================================================

# ------------------------------------------------------------------------------
# General / Production Settings (Module 7)
# ------------------------------------------------------------------------------
APP_VERSION=1.0.0
ENVIRONMENT=development
# ENVIRONMENT must be one of: development, staging, production
DEBUG=true
PROJECT_NAME="OmniBrain – Agentic Multi-Modal RAG Orchestrator"

# ------------------------------------------------------------------------------
# FastAPI Backend Settings
# ------------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:8501", "http://127.0.0.1:8501"]
# UVICORN_WORKERS: keep at 1 -- conversation state, metrics, and evaluation
# history are in-process singletons and are not shared across worker processes.
UVICORN_WORKERS=1

# ------------------------------------------------------------------------------
# Streamlit Frontend Settings (read directly by frontend/app.py via os.getenv)
# ------------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Database Settings
# ------------------------------------------------------------------------------
DATABASE_URL=sqlite:///./omnibrain.db

# ------------------------------------------------------------------------------
# Logging Settings
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text
# LOG_FORMAT must be one of: text, json (json is friendlier to log aggregators)
LOG_FILE_PATH=logs/omnibrain.log
LOG_ROTATION="10 MB"
LOG_BACKUP_COUNT=5

# ------------------------------------------------------------------------------
# OpenAI Settings (used by every LLM-backed agent/service across Modules 3-6)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
LLM_REQUEST_TIMEOUT_SECONDS=30.0
LLM_MAX_RETRIES=2

# ------------------------------------------------------------------------------
# Ingestion / Chunking Settings (Module 2)
# ------------------------------------------------------------------------------
UPLOAD_DIR=storage/uploads
ASSETS_DIR=storage/assets
MAX_FILE_SIZE_MB=50
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_RETRIES=3

# ------------------------------------------------------------------------------
# Vector Database Settings (Module 2 -- Qdrant preferred, auto-falls back to
# a local FAISS index if Qdrant is unreachable)
# ------------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=omnibrain_vectors
VECTOR_DIMENSION=1536
FAISS_STORAGE_PATH=storage/faiss_index

# ------------------------------------------------------------------------------
# Semantic Search Settings (Module 2)
# ------------------------------------------------------------------------------
SEARCH_DEFAULT_TOP_K=5

# ------------------------------------------------------------------------------
# Vision Analysis Settings (Module 4)
# ------------------------------------------------------------------------------
VISION_MODEL=gpt-4o
VISION_MIN_IMAGE_DIMENSION=32
VISION_MAX_IMAGES_PER_DOCUMENT=30

# ------------------------------------------------------------------------------
# SQL Intelligence Settings (Module 5)
# ------------------------------------------------------------------------------
SQL_MAX_ROWS=200

# ------------------------------------------------------------------------------
# Guardrail Settings (Module 6)
# ------------------------------------------------------------------------------
GUARDRAILS_ENABLED=true
GUARDRAIL_MAX_INPUT_LENGTH=4000

# ------------------------------------------------------------------------------
# Observability Settings (Module 6)
# ------------------------------------------------------------------------------
METRICS_HISTORY_SIZE=500
EVALUATION_HISTORY_SIZE=200
